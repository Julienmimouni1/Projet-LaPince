// Get a free hosted Postgres database in seconds: `npx create-db`

//Aucune output personnalisée.
//✔ Résultat
//Prisma Client est toujours installé dans le répertoire standard : node_modules/@prisma/client

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  first_name    String
  last_name     String
  email         String         @unique
  password      String
  photo         String?
  budgets       Budget[]
  alerts        Alert[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt()
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  expiresAt DateTime

  @@map("refresh_tokens")
}

model Budget {
  id           Int      @id @default(autoincrement())
  limit_amount Float
  period       String
  id_category  Int
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()

  @@map("budgets")
}

model Alert {
  id             Int      @id @default(autoincrement())
  categoryName   String // nom de la catégorie concernée
  exceededAmount Float // montant du dépassement par rapport au budget
  isRead         Boolean  @default(false) // alerte lue ou non
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@map("alerts")
}
